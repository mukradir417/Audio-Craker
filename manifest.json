{
  "manifest_version": 3,
  "name": "Mitu YT Audio Pro",
  "version": "1.0",
  "description": "Premium extension with Firebase License Authentication.",
  "permissions": ["activeTab", "scripting", "downloads", "storage"],
  "host_permissions": ["<all_urls>", "https://firestore.googleapis.com/*"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Start Audio Master",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}